# ── Required ────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
OPENAI_API_KEY=sk-your-openai-api-key

# ── Environment ─────────────────────────────────────────────
# Required. Set to "production" on Render.
ENVIRONMENT=development

# ── CORS ────────────────────────────────────────────────────
# Required. Comma-separated allowed frontend origins.
# Production value: https://clinicaireply.com
# Local dev override: http://localhost:1201
CORS_ORIGINS=https://clinicaireply.com

# Required in production. Used for links in email and redirects.
# Production value: https://clinicaireply.com
# Local dev override: http://localhost:1201
FRONTEND_APP_URL=https://clinicaireply.com

# ── Google Sheets credentials (set ONE of these) ───────────
# 1) Base64-encoded full service account JSON (recommended for hosting platforms)
GOOGLE_CREDENTIALS_B64=
# 2) Raw JSON string (single-line JSON)
GOOGLE_CREDENTIALS_JSON=
# 3) Absolute or relative path to service account JSON file (local dev only)
GOOGLE_CREDENTIALS_PATH=

# ── Email notifications (Resend) ────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_DOMAIN=

# ── Stripe billing ──────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_PREMIUM=

# ── Twilio SMS ──────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=

# ── Admin / internal tools ──────────────────────────────────
ADMIN_SECRET=
