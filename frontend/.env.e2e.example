# Playwright authenticated suite (`pnpm run e2e:auth` / `pnpm run e2e:all`) only.
# Copy to `.env.e2e` in this folder (never commit real secrets).
#
# Prereqs:
# - `frontend/.env` must set NEXT_PUBLIC_API_URL to a running backend.
# - One-time browser install from frontend/: `pnpm exec playwright install chromium`
# - Seed a test user: `cd ../backend && python create_test_user.py` — use the printed email/password here.

E2E_USER_EMAIL=
E2E_USER_PASSWORD=
