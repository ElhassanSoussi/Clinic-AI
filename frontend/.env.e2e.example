# Copy to `frontend/.env.e2e` and fill in. Playwright loads this file in `playwright.config.ts`
# (Node only — it does not replace Vite env).
#
# Required for `pnpm run e2e:auth` (and the authenticated block in `e2e:critical`):
E2E_USER_EMAIL=
E2E_USER_PASSWORD=
#
# The dev server (`pnpm run dev`) must point at a working API. Set in `frontend/.env`:
#   NEXT_PUBLIC_API_URL=http://127.0.0.1:7001/api
#
# Seed a user (Supabase service role / backend env required):
#   cd backend && python create_test_user.py
# Defaults: TEST_USER_EMAIL / TEST_USER_PASSWORD or printed password — use the same values in `.env.e2e`.
