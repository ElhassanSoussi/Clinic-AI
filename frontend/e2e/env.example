# Required for Playwright: copy this file to ../.env.e2e (in the frontend folder) and set both variables.
# Authenticated E2E tests are never skipped; without these values the suite fails with a clear error.
# Playwright loads ../.env.e2e automatically (see playwright.config.ts).
# The backend must be running and reachable (default API http://127.0.0.1:7001/api).
#
# Create a user with: python backend/create_test_user.py (see backend README / DEPLOYMENT.md).

E2E_USER_EMAIL=
E2E_USER_PASSWORD=
