# ── Required ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Backend API ─────────────────────────────────────────────
# Public backend URL for browser requests.
# Local dev example:
#   http://127.0.0.1:7001/api
# Production example:
#   https://your-backend.onrender.com/api
NEXT_PUBLIC_API_URL=http://127.0.0.1:7001/api

# Optional server-side override for Next.js route handlers / server fetches.
# Leave blank unless you want server-side requests to use a different URL.
# Example:
#   https://your-backend.onrender.com/api
API_INTERNAL_URL=

# Optional feature flag for Microsoft OAuth button visibility.
NEXT_PUBLIC_ENABLE_MICROSOFT_OAUTH=false
