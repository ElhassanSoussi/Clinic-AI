# ── Required ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Backend API ─────────────────────────────────────────────
# Required in every environment.
# Local dev example: http://127.0.0.1:7001/api
# Production example: https://your-backend.onrender.com/api
NEXT_PUBLIC_API_URL=

# Optional server-side override for Next.js route handlers / server fetches.
# Leave blank unless server-side requests should use a different backend URL.
API_INTERNAL_URL=

# Optional feature flag for Microsoft OAuth button visibility.
NEXT_PUBLIC_ENABLE_MICROSOFT_OAUTH=false
