# =============================================================================
# Clinic AI — frontend environment (copy to .env.local for local dev)
# =============================================================================
#
# Where this runs          | What to know
# -------------------------|--------------------------------------------------
# Local                    | All REQUIRED vars below. Site URL optional.
# Vercel Preview           | Vercel sets VERCEL_URL. Set API + Supabase to a
#                          | dev/staging backend or shared project as intended.
# Vercel Production        | REQUIRED + set NEXT_PUBLIC_SITE_URL to the public
#                          | domain (see RELEASE.md). Add Sentry DSN if using.
#
# =============================================================================
# REQUIRED — app will misbehave or error if missing
# =============================================================================

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Browser + server components use this for API calls. No trailing path beyond /api.
# Local:  http://127.0.0.1:7001/api
# Prod:   https://api.clinicaireply.com/api
NEXT_PUBLIC_API_URL=https://api.clinicaireply.com/api

# =============================================================================
# STRONGLY RECOMMENDED — production / custom domain
# =============================================================================

# Canonical origin for metadata, Open Graph, and relative URL resolution.
# Set on Vercel Production to your public site (e.g. https://clinicaireply.com).
# If unset: uses VERCEL_URL on Vercel (good for previews), else hardcoded product default.
NEXT_PUBLIC_SITE_URL=

# =============================================================================
# OPTIONAL — server-side API (Next route handlers / SSR fetches)
# =============================================================================

# Overrides backend URL for server-only requests. Leave unset to use NEXT_PUBLIC_API_URL.
API_INTERNAL_URL=https://api.clinicaireply.com/api

# =============================================================================
# OPTIONAL — feature flags (OAuth button visibility)
# =============================================================================

NEXT_PUBLIC_ENABLE_GOOGLE_OAUTH=true
# Set true only after Microsoft/Azure is configured in Supabase Auth.
NEXT_PUBLIC_ENABLE_MICROSOFT_OAUTH=true

# =============================================================================
# OPTIONAL — observability (Sentry)
# =============================================================================

# Required for any Sentry reporting. Same DSN is typical for client + server.
NEXT_PUBLIC_SENTRY_DSN=

# Optional: server/edge only; if set, preferred over NEXT_PUBLIC_SENTRY_DSN on server.
# SENTRY_DSN=

# Optional: tag browser events as preview vs production (mirrors VERCEL_ENV).
# Vercel does not expose VERCEL_ENV to the browser unless you set this.
# NEXT_PUBLIC_VERCEL_ENV=preview

# =============================================================================
# OPTIONAL — build / CI only (not needed for runtime)
# =============================================================================
# Set in CI or Vercel if you upload source maps to Sentry:
#   SENTRY_AUTH_TOKEN=...
#   SENTRY_ORG=your-org-slug
#   SENTRY_PROJECT=your-project-slug
#
# Vercel also provides automatically for some features:
#   VERCEL_URL, VERCEL_ENV, CI
