# ── Required ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Backend API ─────────────────────────────────────────────
# Required in every environment.
# Local dev example: http://127.0.0.1:7001/api
# If you open the frontend over a LAN IP in development, the browser will
# reuse that hostname automatically when this points to localhost/127.0.0.1.
# Production value: https://api.clinicaireply.com/api
NEXT_PUBLIC_API_URL=https://api.clinicaireply.com/api

# Optional server-side override for Next.js route handlers / server fetches.
# Leave blank unless server-side requests should use a different backend URL.
# Production value: https://api.clinicaireply.com/api
API_INTERNAL_URL=https://api.clinicaireply.com/api

# Optional feature flags for social sign-in button visibility.
NEXT_PUBLIC_ENABLE_GOOGLE_OAUTH=true
NEXT_PUBLIC_ENABLE_MICROSOFT_OAUTH=true
