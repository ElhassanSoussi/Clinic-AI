{
  "python.defaultInterpreterPath": "${workspaceFolder}/backend/venv/bin/python",
  "python.analysis.diagnosticMode": "openFilesOnly",
  "python.analysis.ignore": [
    "/opt/homebrew/**",
    "**/backend/venv/**",
    "**/.next/**",
    "**/.mypy_cache/**",
    "**/.pytest_cache/**",
    "**/.ruff_cache/**",
    "**/.tox/**",
    "**/.nox/**",
    "**/.direnv/**"
  ],
  "eslint.workingDirectories": [
    {
      "directory": "frontend",
      "changeProcessCWD": true
    }
  ],
  "json.schemaDownload.enable": false,
  "js/ts.tsdk.path": "frontend/node_modules/typescript/lib",
  "js/ts.tsdk.promptToUseWorkspaceVersion": true,
  "files.associations": {
    "*.sql": "plaintext",
    "20260327_add_onboarding_branding.sql": "plaintext",
    "backend/migrations/*.sql": "plaintext",
    "**/backend/migrations/*.sql": "plaintext"
  },
  "problems.exclude": {
    "**/backend/migrations/20260327_add_onboarding_branding.sql": true
  },
  "mssql.intelliSense.enableIntelliSense": false,
  "mssql.intelliSense.enableErrorChecking": false,
  "dbcode.enableLinting": false,
  "workbench.editor.autoLockGroups": {
    "default": true,
    "workbench.editor.chatSession": true,
    "workbench.editor.chatDebug": true,
    "workbench.editorinputs.searchEditorInput": true,
    "agentSessionsWelcomePage": true,
    "workbench.editorinputs.browser": true,
    "notebookOutputEditor": true,
    "jupyter-notebook": true,
    "dbcode-notebook": true,
    "copilot-chat-replay": true,
    "ijnb-notebook": true,
    "repl": true,
    "workbench.editors.gettingStartedInput": true,
    "imagePreview.previewEditor": true,
    "vscode.audioPreview": true,
    "vscode.videoPreview": true,
    "jsProfileVisualizer.cpuprofile.table": true,
    "jsProfileVisualizer.heapprofile.table": true,
    "jsProfileVisualizer.heapsnapshot.table": true,
    "dbcode.dataFileViewer": true,
    "phpprofiler.cachegrind": true,
    "gitlens.rebase": true,
    "mssql.executionPlanView": true,
    "jupyter-data-wrangler": true,
    "chatgpt.conversationEditor": true,
    "decompiled.javaClass": true,
    "java.formatterSettingsEditor": true,
    "workbench.input.interactive": true,
    "mainThreadWebview-markdown.preview": true
  },
  "workbench.editor.centeredLayoutFixedWidth": true,
  "workbench.editor.wrapTabs": true,
  "workbench.editor.swipeToNavigate": true,
  "workbench.editor.alwaysShowEditorActions": true,
  "workbench.editor.closeOnFileDelete": true,
  "workbench.editor.enablePreviewFromCodeNavigation": true,
  "workbench.editor.enablePreviewFromQuickOpen": true,
  "workbench.editor.highlightModifiedTabs": true,
  "workbench.editor.limit.perEditorGroup": true,
  "workbench.editor.limit.excludeDirty": true,
  "workbench.editor.limit.enabled": true,
  "workbench.editor.pinnedTabsOnSeparateRow": true,
  "workbench.editor.preferHistoryBasedLanguageDetection": true,
  "workbench.editor.revealIfOpen": true,
  "workbench.editor.scrollToSwitchTabs": true,
  "workbench.editor.sharedViewState": true,
  "workbench.editor.showTabIndex": true,
  "github.copilot.chat.agent.autoFix": true,
  "github.copilot.chat.claudeAgent.allowDangerouslySkipPermissions": true,
  "github.copilot.chat.rateLimitAutoSwitchToAuto": true,
  "github.copilot.chat.scopeSelection": true,
  "github.copilot.chat.anthropic.thinking.forceExtendedThinking": true,
  "github.copilot.chat.backgroundCompaction": true,
  "github.copilot.chat.codesearch.enabled": true,
  "github.copilot.chat.conversationTranscriptLookup.enabled": true,
  "github.copilot.chat.copilotMemory.enabled": true,
  "github.copilot.chat.alternateGeminiModelFPrompt.enabled": true,
  "github.copilot.chat.alternateGptPrompt.enabled": true,
  "github.copilot.chat.anthropic.contextEditing.mode": "clear-thinking",
  "github.copilot.chat.anthropic.tools.websearch.enabled": true,
  "github.copilot.chat.getSearchViewResultsSkill.enabled": true,
  "github.copilot.chat.githubMcpServer.lockdown": true,
  "github.copilot.chat.githubMcpServer.enabled": true,
  "github.copilot.chat.githubMcpServer.readonly": true,
  "github.copilot.chat.gpt54ConcisePrompt.enabled": true,
  "github.copilot.chat.gpt54LargePrompt.enabled": true,
  "github.copilot.chat.languageContext.fix.typescript.enabled": true,
  "github.copilot.chat.languageContext.inline.typescript.enabled": true,
  "github.copilot.chat.languageContext.typescript.includeDocumentation": true,
  "github.copilot.chat.newWorkspace.useContext7": true,
  "github.copilot.chat.notebook.followCellExecution.enabled": true,
  "github.copilot.chat.notebook.enhancedNextEditSuggestions.enabled": true,
  "github.copilot.chat.responsesApi.promptCacheKey.enabled": true,
  "github.copilot.chat.responsesApiContextManagement.enabled": true,
  "github.copilot.chat.switchAgent.enabled": true,
  "python.analysis.autoTranslateDocstrings": true,
  "githubPullRequests.experimental.useQuickChat": true,
  "chat.disableAIFeatures": false,
  "dataWrangler.experiments.copilot.enabled": true,
  "claudeCode.useTerminal": true,
  "cursor.composer.shouldChimeAfterChatFinishes": false,
  "cursor.general.emailPrivacyEnabled": true,
  "cursor.composer.shouldAutoSaveNonAgent": false
}